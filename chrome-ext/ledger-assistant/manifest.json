{
  "manifest_version": 3,
  "name": "数据需求台账助手",
  "description": "在OA数据需求页面一键解析并写入台账，登记提取记录",
  "version": "1.1.0",
  "permissions": ["storage", "activeTab", "sidePanel", "tabs", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "打开台账助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://scitsmpro.paas.sc.ctc.com/aiops/app/form/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": ["<all_urls>"]
}
